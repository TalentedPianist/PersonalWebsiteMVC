@using BlazorPagination
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.JSInterop
@using PersonalWebsiteMVC.Models
@inject ApplicationDbContext _db
@inject IJSRuntime JS
@inject IHttpContextAccessor _http
@inject NavigationManager _nav

<div id="Comments">
    @if (_db.Comments.Count() == 0)
    {
        <h2>Comments</h2>
        <p>No comments have been found at this time. Be the first to add a comment using the form below.</p>
        <CommentForm />
    }
    else
    {
        <h3>Comments</h3>
        if (_data!.Results.Count() == 0)
        {
            <p>No comments have been found for this post. Be the first to add a comment using the form below.</p>
            <CommentForm />
        }
        else
        {
            <div id="Comments">
                @foreach (Comments comment in _data.Results)
                {

                    <div class="flex flex-row flex-1">
                        <img src="http://www.gravatar.com/avatar/?d=mp" class="mr-10">
                        Posted by @comment.CommentAuthor on @comment.CommentDate.ToString("dddd dd MMMM yyyy")
                    </div>
                    <p class="text-xl">@((MarkupString)comment.CommentContent!)</p>
                }
                <p>You are currently on page @_data.CurrentPage of @_data.PageCount.</p>
                <BlazorPager CurrentPage="@_data.CurrentPage" PageCount="@_data.PageCount" VisiblePages="3" ShowFirstLast="true" ShowPageNumbers="true" FirstText="&laquo;" LastText="&raquo;" NextText="&rsaquo;" PreviousText="&lsaquo;" OnPageChanged="(async e => { _page = e; GetData(); })" />
            </div>
            <CommentForm />
        }
    }

</div>


@code {
    [Parameter]
    public int PostID { get; set; }
  
    private PagedResult<Models.Comments>? _data;
    private int _page = 1; 
    private void GetData()
    {
        _data = _db.Comments.ToPagedResult(_page, 2);
        StateHasChanged();
    }

    protected override void OnInitialized()
    {
        GetData();
    }
}