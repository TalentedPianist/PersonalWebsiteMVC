@using System.Text.RegularExpressions
@using PersonalWebsiteMVC.Data
@inject ApplicationDbContext _db
@inject NavigationManager nav
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.WebUtilities
@using PersonalWebsiteMVC.Components.Mobile
@using MudBlazor
@using PersonalWebsiteMVC.Models


@if (_db.Posts.Count() == 0)
{
    <div id="Blog">
        <h1 class="text-4xl text-black">Blog</h1>

        <p>No posts have been found just now. Please check back later.</p>
    </div>
}
else
{
    if (Id > 0)
    {
        var uri = nav.ToAbsoluteUri(nav.Uri);
        if (uri.Fragment.Contains("Comments"))
        {
            
        }
        else
        {
            var post = _db.Posts.Where(p => p.PostID == Id).FirstOrDefault();
            <div id="SinglePost">
                <a href="#Blog" @onclick="GoBack" class="text-underline">Back</a>
                <h1>@post!.PostTitle</h1>
                <p>@((MarkupString)post.PostContent!)</p>
            
                <BlogComments PostID="@post.PostID" />
            </div>
        }
    }
    else
    {
        <div id="Blog" style="overflow-y: scroll">
                <h1>Blog</h1>
                <Virtualize ItemsProvider="LoadPosts" Context="item" ItemSize="1" OverscanCount="1">
                    <ItemContent>
                    <section>
                    <div id="PostContent">
                    <h2>@item.PostTitle</h2>
                    @{
                        var post = Truncate (item.PostContent!, 150);
                        @RemoveHTMLTags(post)
                    }
                    <button>Read</button>
                    </div>
                    </section>
                    </ItemContent>
                </Virtualize>
            </div>
        
    }
}

@functions {
    public static string Truncate(string value, int maxChars)
    {
        return value.Length <= maxChars ? value : value.Substring(0, maxChars) + "....";
     
    }

    public static string RemoveHTMLTags(string html)
    {
        return Regex.Replace(html, "<.*?>", string.Empty);
    }
}

@code {
    public string? Message { get; set; }

    public ICollection<PersonalWebsiteMVC.Models.Posts> Model { get; set; } = new List<PersonalWebsiteMVC.Models.Posts>();

    private async ValueTask<ItemsProviderResult<PersonalWebsiteMVC.Models.Posts>> LoadPosts(ItemsProviderRequest request)
    {
        await Task.Yield();
        var numPosts = _db.Posts.Count();
        var posts = _db.Posts.Skip(request.StartIndex).Take(numPosts);
        return new ItemsProviderResult<PersonalWebsiteMVC.Models.Posts>(posts, _db.Posts.Count());
    }



    [SupplyParameterFromQuery(Name = "id")]
    public int Id { get; set; }

    public async Task ViewPost(int id)
    {
        var query = new Dictionary<string, string>
        {
            {"id", id.ToString() },
        };
        nav.NavigateTo(QueryHelpers.AddQueryString("/post", query!));
        await JS.InvokeVoidAsync("location.reload");
    }

    public async Task ViewComments(int PostID)
    {
        await Task.CompletedTask;
    }


    void GoBack() 
    {
        nav.NavigateTo("#Blog");
        StateHasChanged();
    }

}