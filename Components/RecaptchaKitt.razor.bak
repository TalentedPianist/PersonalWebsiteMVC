@using PersonalWebsiteMVC.Models
@using PersonalWebsiteMVC.Services
@implements IDisposable
@inject IReCaptchaFormClient client
@using KITT.Web.ReCaptcha

<ReCaptcha
    SiteKey="6Lcu4zIqAAAAAGwRGrbhwIT_VWW4NVA5tbnSKgDB"
    @bind-Value="Value"
    Size="KITT.Web.ReCaptcha.Blazor.v2.Size.Normal"
    Theme="KITT.Web.ReCaptcha.Blazor.v2.Theme.Light"
    TabIndex="1" 
    
    />


@code {
    public string Message { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }
    [Parameter]
    public string Value { get; set; } = string.Empty;

    private EditContext? context;
    private ReCaptchaModel model = new();
    private bool disabled = true;
    private string? message;
    private bool isSuccessMessage;
    private string[] errorCodes = [];
    
    protected override void OnInitialized()
    {
        context = new EditContext(model);
        context.OnFieldChanged += OnFieldChangedHandler;
    }

    private void OnFieldChangedHandler(object? sender, FieldChangedEventArgs e)
    {
        disabled = !(context!.Validate());
        
        StateHasChanged();
    }

    void IDisposable.Dispose()
    {
        context!.OnFieldChanged -= OnFieldChangedHandler;
    }

   
}