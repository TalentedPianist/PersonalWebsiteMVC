@using System.Text.RegularExpressions

@layout BlogLayout


@if (_db.Posts.Count() == 0)
{
    <MudText Color="Color.Primary" Typo="Typo.h1">Blog</MudText>
    <MudText Typo="Typo.body1">No posts have been found just now.  Please check back later.</MudText>
}
else
{
    if (Id > 0)
    {
        var uri = _nav.ToAbsoluteUri(_nav.Uri);
        if (uri.Fragment.Contains("Comments"))
        {
            <BlogComments PostID="Id" />
        }
        else
        {
            var post = _db.Posts.Where(p => p.PostID == Id).FirstOrDefault();
            <div id="SinglePost">
                <h1>Blog</h1>
                <h2>@post!.PostTitle</h2>
                <img src=@($"Uploads/{post.FeaturedImage}")>
                @((MarkupString)post.PostContent!)
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="(() => ViewComments(post.PostID))">Comments</MudButton>
            </div>
        }
    }
    else
    {
        <div id="Blog">
            <div id="wave-container">
                <section>
                    <h1>Blog</h1>


                    @foreach (var item in _db.Posts)
                    {

                        try
                        {
                            var result = Truncate(item.PostContent!, 200);

                            <MudCard Class="BlogItem">
                                <MudCardMedia Image=@($"/Uploads/{item.FeaturedImage}") Height="200" />
                                <MudCardContent>
                                    <h2>@item.PostTitle</h2>
                                    <p>@RemoveHTMLTags(result)</p>
                                </MudCardContent>
                                <MudCardActions>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="(() => ViewPost(item.PostID))">Read More</MudButton>
                                </MudCardActions>
                            </MudCard>
                        }
                        catch (NullReferenceException ex)
                        {
                            @ex.Message
                        }

                    }
                    <button class="loadMorePosts">Load More</button> 
                </section>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="#9ff500" fill-opacity="1" d="M0,160L48,165.3C96,171,192,181,288,160C384,139,480,85,576,90.7C672,96,768,160,864,202.7C960,245,1056,267,1152,266.7C1248,267,1344,245,1392,234.7L1440,224L1440,0L1392,0C1344,0,1248,0,1152,0C1056,0,960,0,864,0C768,0,672,0,576,0C480,0,384,0,288,0C192,0,96,0,48,0L0,0Z"></path></svg>

                
            </div>
  
            </div>

    }
}

@functions { 
    public static string Truncate(string value, int maxChars)
    {
        return value.Length <= maxChars ? value : value.Substring(0, maxChars) + "....";
    }

    public static string RemoveHTMLTags(string html)
    {
        return Regex.Replace(html, "<.*?>", string.Empty);
    }
}


@code { 
        [SupplyParameterFromQuery(Name="id")]
        public int Id { get; set; } = new();
    public string? Message { get; set; }
    [Inject]
    public ApplicationDbContext _db { get; set; } = default!;
    [Inject]
    public NavigationManager _nav { get; set; } = default!;
    [Inject]
    public IJSRuntime JS { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("LoadMore");
        }

    }


#pragma warning disable
    public async Task ViewPost(int id)
    {
        var query = new Dictionary<string, string>
        {
            {"id", id.ToString() },
        };
        _nav.NavigateTo(QueryHelpers.AddQueryString("#Blog", query));
        await JS.InvokeVoidAsync("location.reload");
    }

    public async Task ViewComments(int id)
    {
        var query = new Dictionary<string, string>
        {
            {"id", id.ToString() }
        };
        _nav.NavigateTo(QueryHelpers.AddQueryString("#Comments", query));
        await JS.InvokeVoidAsync("location.reload");
    }
}