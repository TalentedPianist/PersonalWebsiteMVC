@using Sitko.Blazor.CKEditor
@using Sitko.Blazor.CKEditor.Bundle
@using System.Linq.Expressions



<CKEditor Value="@Value" ValueChanged="@OnEditorValueChanged" Placeholder="Your thoughts on this post" Config="config" Style="color: black" ValueExpression="ValueExpression" />

@code { 
    [Parameter]
    public RenderFragment? ChildContent { get; set; }
    [Parameter]
    public string? Value { get; set; }
    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }
    

    private CKEditorConfig? config;
    protected override void OnInitialized()
    {
        config = CKEditorBundleOptions.DefaultConfig.WithHtmlEditing();
        config.Toolbar = new CKEditorToolbar
        {
            Items = 
            [
                "bold"
            ]
        };
        
    }

    private async Task OnEditorValueChanged(string newValue)
    {
        try { 
        Value = newValue;
        await ValueChanged.InvokeAsync(newValue);
        } catch (JSDisconnectedException ex) 
        {
            Console.WriteLine(ex.Message);
        }
    }

    [Parameter]
    public Expression<Func<string>>? ValueExpression { get; set; }
}