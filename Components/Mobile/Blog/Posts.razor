@using System.Text.RegularExpressions
@using PersonalWebsiteMVC.Data
@inject ApplicationDbContext _db
@inject NavigationManager nav
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.WebUtilities
@using PersonalWebsiteMVC.Components.Mobile.Blog
@using MudBlazor

@if (_db.Posts.Count() == 0)
{
    <div id="Blog">
        <h1 class="text-4xl text-black">Blog</h1>

        <p>No posts have been found just now. Please check back later.</p>
    </div>
}
else
{
    if (Id > 0)
    {
        var uri = nav.ToAbsoluteUri(nav.Uri);
        if (uri.Fragment.Contains("Comments"))
        {
            
        }
        else
        {
            var post = _db.Posts.Where(p => p.PostID == Id).FirstOrDefault();
            <div id="SinglePost">
                <h1>@post!.PostTitle</h1>
                @((MarkupString)post.PostContent!)
            
                <BlogComments PostID="@post.PostID" />
            </div>
        }
    }
    else
    {
        <div id="Blog">
            <h1>Blog</h1>

            <section>
                @foreach (var item in Model)
                {
                    var result = Truncate(item.PostContent!, 150);

                    <section>

                        @if (item.FeaturedImage != null)
                        {
                            <MudCardMedia Image=@($"Uploads/{item.FeaturedImage}") Height="200" />
                        }

                        <div id="PostContent">
                            <h2>@item.PostTitle</h2>
                            @RemoveHTMLTags(result)
                            <br>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="(() => ViewPost(item.PostID))">
                                Read
                                More</MudButton>
                        </div>
                        
                    </section>
                }
            </section>
        </div>
    }
}

@functions {
    public static string Truncate(string value, int maxChars)
    {
        return value.Length <= maxChars ? value : value.Substring(0, maxChars) + "....";
    }

    public static string RemoveHTMLTags(string html)
    {
        return Regex.Replace(html, "<.*?>", string.Empty);
    }
}

@code {
    public string? Message { get; set; }

    public IEnumerable<PersonalWebsiteMVC.Models.Posts> Model { get; set; } = new List<PersonalWebsiteMVC.Models.Posts>();

    protected override void OnParametersSet()
    {
        Model = _db.Posts.ToList();
    }

    [SupplyParameterFromQuery(Name = "id")]
    public int Id { get; set; }

    public async Task ViewPost(int id)
    {
        var query = new Dictionary<string, string>
{
{"id", id.ToString() },
};
        nav.NavigateTo(QueryHelpers.AddQueryString("#Blog", query!));
        await Task.CompletedTask;
    }

    public async Task ViewComments(int PostID)
    {
        await Task.CompletedTask;
    }
}