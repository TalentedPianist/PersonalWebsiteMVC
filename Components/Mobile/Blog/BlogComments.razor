@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.JSInterop
@using PersonalWebsiteMVC.Models
@inject ApplicationDbContext _db
@inject IJSRuntime JS
@inject IHttpContextAccessor _http
@inject NavigationManager _nav

<div id="Comments">
    @if (_db.Comments.Count() == 0)
    {
        <h2>Comments</h2>
        <p>No comments have been found at this time.  Be the first to add a comment using the form below.</p>
    }
    else 
    {
        <h3>Comments</h3>
        if (AllComments.Count() == 0)
        {
            <p>No comments have been found for this post.  Be the first to add a comment using the form below.</p>
            <CommentForm />
        }
        else
        {
            foreach (Comments comment in AllComments)
            {
                <MudText>
                    <img src="http://www.gravatar.com/avatar/?d=mp">
                    Posted by @comment.CommentAuthor on @comment.CommentDate.ToString("dddd dd MMMM yyyy")

                    @((MarkupString)comment.CommentContent!)
                </MudText>
            }
        }
    }

</div>


@code { 
    public string? Message { get; set; }

    public void HandleHiddenChanged(ChangeEventArgs e)
    {
        Message = e.Value!.ToString();
    }

    [Parameter]
    public int PostID { get; set; }

    [SupplyParameterFromForm]
    public Comments? Model { get; set; } = new Comments();
    public List<Comments> AllComments { get; set; } = new List<Comments>();
    
    protected override async Task OnParametersSetAsync()
    {
        await Task.CompletedTask;
    }

    public async Task HandleValidSubmit()
    {
        Comments comment = new Comments();
        comment.CommentAuthor = Model!.CommentAuthor;
        comment.CommentAuthorEmail = Model.CommentAuthorEmail;
        comment.CommentAuthorUrl = Model.CommentAuthorUrl;
        comment.CommentContent = Model.CommentContent;
        comment.PostID = PostID;
        comment.CommentDate = DateTime.Now;
        comment.CommentAuthorIP = _http.HttpContext!.Connection.RemoteIpAddress!.ToString();
        _db.Comments.Add(comment);
        _db.SaveChanges();

        // Set up query string for redirection back to this element
        var query = new Dictionary<string, string>();

    }
}