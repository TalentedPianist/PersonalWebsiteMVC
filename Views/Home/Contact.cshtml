@{
}
@model ContactFormModel


<div id="Contact">

    <section>
        <article>
            <h1>Contact</h1>

            @TempData["Message"]

            <form method="post" asp-action="ContactForm" asp-controller="Contact">
                <div class="text-danger" asp-validation-summary="All"></div>
                <div>
                    <label>Name:</label>
                    <input asp-for="Name" placeholder="John Smith">
                </div>
                <div>
                    <label>Email:</label>
                    <input asp-for="Email" placeholder="john@johnsmith.com">
                </div>
                <div>
                    <label>Website:</label>
                    <input asp-for="Website" placeholder="https://www.johnsmith.com">
                </div>

                <div>
                    <label>Message:</label>

                        <textarea asp-for="Message" id="ckeditor1"></textarea>
                    
                </div>

                <div>
                    <div id="g-recaptcha" data-sitekey="6LeCBlUrAAAAAGJFT1Rt-4hojR6NfEvqzsvZwnOz" class="recaptcha">
                    </div>
                </div>
                <button type="submit">Submit</button>
            </form>
        </article>
    </section>
</div>

@section Scripts {
    <script>
        $("button").on('click', function (e) {
            e.preventDefault();
            let reCaptchaResponse = grecaptcha.getResponse();
            if (reCaptchaResponse) {
                $.ajax({
                    type: "GET",
                    url: "@Url.Action("Captcha", "Contact")",
                    data: { userResponse: reCaptchaResponse },
                    success: function (data) {
                        $("form").submit();
                    },
                    error: function (error) {
                        console.log(error);
                    }
                });
            } else {
                $("form").prepend("<p>You must click the reCaptcha to prove that you're not a robot.</p>");
            }
        });
    </script>
}
