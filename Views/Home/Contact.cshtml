@{
}
@model ContactFormModel
@using AspNetCore.ReCaptcha 

<div id="Contact">

    <section>
        <article>
            <h1>Contact</h1>

            @TempData["Message"]

            <form method="post" asp-action="ContactForm" asp-controller="Contact">
                <div>
                    <label>Name:</label>
                    <input asp-for="Name" placeholder="John Smith">
                </div>
                <div>
                    <label>Email:</label>
                    <input asp-for="Email" placeholder="john@johnsmith.com">
                </div>
                <div>
                    <label>Website:</label>
                    <input asp-for="Website" placeholder="https://www.johnsmith.com">
                </div>
                <div>
                    <label>Message:</label>
                    <textarea asp-for="Message" id="ckeditor1"></textarea>
                </div>
     
                <button type="submit">Submit</button>
            </form>
        </article>
    </section>
</div>


