@{
}


<header>
    <nav>
        <ul>
            <li><a asp-action="Index" asp-controller="Home">Home</a></li>
            <li><a asp-action="About" asp-controller="Home">About</a></li>
            <li><a asp-action="Index" asp-controller="Home" asp-area="Blog">Blog</a></li>
            <li><a asp-action="Index" asp-controller="Home" asp-area="Photos">Photos</a></li>
            <li><a asp-action="Index" asp-controller="Home" asp-area="Portfolio">Portfolio</a></li>
            <li><a asp-action="Index" asp-controller="Contact">Contact</a></li>
        </ul>
    </nav>
    <div class="coverPhoto"></div>
</header>

<main>
    @{
        string path = Context.Request.Path.Value!;
        switch (path)
        {
            case var s when path.Contains("Blog"):
                <partial name="~/Areas/Blog/Views/TabletLayout.cshtml" />
                break;
            default:
                <partial name="~/Views/Home/Index.cshtml" />
                break;

        }
    }
   
</main>



