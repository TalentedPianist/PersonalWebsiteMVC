@model MixModel

<div class="commentCount">
    @if (Model.AllComments.Count == 0)
    {
        <p>No comments have been found for this post. Be the first to share your thoughts on this post using the form below.
        </p>
    }
</div>

<form method="post">
    <div asp-validation-summary="All"></div>
    <div>
        <label>Name:</label>
        <input id="name" placeholder="John Smith">
    </div>
    <div>
        <label>Email:</label>
        <input id="email" placeholder="john@johnsmith.com">
    </div>
    <div>
        <label>Website:</label>
        <input id="website" placeholder="https://www.johnsmith.com">
    </div>
    <div>
        <label asp-for="Comments.CommentContent">Comment:</label>
        <textarea rows="10" cols="30" id="ckeditor1" placeholder="This is a great website...."></textarea>
    </div>
    <input type="hidden" name="PostTitle" value="@Model.Posts!.PostTitle">
    <input type="hidden" asp-for="Comments.PostID" value="@Model.Posts!.PostID">
    @* <div>
        <p>Please take a second to do the captcha and prove you're not a robot. This helps me fight spam. Thank you.</p>
        <div id="g-recaptcha" data-sitekey="6LeCBlUrAAAAAGJFT1Rt-4hojR6NfEvqzsvZwnOz"></div>
    </div> *@

    <button type="submit">Comment</button>
</form>