@model MixModel



@if (Model is not null)
{
    <div id="SinglePost">



        <a href="javascript:history.go(-1)">Back</a>

        <h1>@Model.Posts!.PostTitle</h1>

        @Html.Raw(Model.Posts.PostContent)

        

        <partial name="~/Views/Mobile/Comments.cshtml" model="Model" />
    </div>
}

@section Scripts {
    <script>
        $("#loadMoreComments").on('click', function (e) {
            e.preventDefault();

            $.get('/Comments/LoadMore', { skip: skip, id: @ViewBag.PostID }, function (data) {
                const batch = $('<div class="postBatch"></div>').hide().append(data);
                $("#Comments").append(batch);
                batch.slideDown('fast');
                skip = skip + 1;
            });
        });

        $('#showLessComments').on('click', function (e) {
            e.preventDefault();
            const lastBatch = $('.postBatch').last();
            lastBatch.slideUp('fast', function () {
                lastBatch.remove();
                skip -= pageSize;
            });
        });
    </script>
}