@{
}
@inject ApplicationDbContext _db

@if (_db.Posts.Count() == 0)
{

    <h1>Blog</h1>

    <p>No posts have been found just now.  Please check back later.</p>

}
else
{
<div id="Blog">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 256"><path fill="#f7e339" fill-opacity="1" d="M0,256L48,218.7C96,181,192,107,288,85.3C384,64,480,96,576,101.3C672,107,768,85,864,112C960,139,1056,213,1152,224C1248,235,1344,181,1392,154.7L1440,128L1440,0L1392,0C1344,0,1248,0,1152,0C1056,0,960,0,864,0C768,0,672,0,576,0C480,0,384,0,288,0C192,0,96,0,48,0L0,0Z"></path></svg>
    <section>
        <h1>Blog</h1>

        @foreach (Posts post in _db.Posts)
        {
            var result = Truncate(post.PostContent!, 200);
            <div class="card">
                <img src="/Uploads/@post.FeaturedImage">
                <div class="card-body">
                    <h5 class="card-title">@post.PostTitle</h5>
                    <p class="card-text">@RemoveHTMLTags(result)</p>
                    <a href="#" class="btn btn-primary">Read More</a>
                </div>
            </div>
        }
        <button class="loadMorePosts">Load More</button>
    </section>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="#9ff500" fill-opacity="1" d="M0,160L48,165.3C96,171,192,181,288,160C384,139,480,85,576,90.7C672,96,768,160,864,202.7C960,245,1056,267,1152,266.7C1248,267,1344,245,1392,234.7L1440,224L1440,0L1392,0C1344,0,1248,0,1152,0C1056,0,960,0,864,0C768,0,672,0,576,0C480,0,384,0,288,0C192,0,96,0,48,0L0,0Z"></path></svg>
</div>

}


@functions {
    static string Truncate(string value, int maxChars)
    {
        return value.Length <= maxChars ? value : value.Substring(0, maxChars) + "....";
    }

    static string RemoveHTMLTags(string html)
    {
        return System.Text.RegularExpressions.Regex.Replace(html, "<.*?>", string.Empty);
    }
}
