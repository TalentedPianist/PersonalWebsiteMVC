@{
}
@model Posts
@inject ApplicationDbContext _db

@TempData["Message"]


<div id="Post">

	<a href='@($"{Context.Request.Scheme}://{Context.Request.Host.Value}#Blog")'>Back</a>
	<h1>@Model.PostTitle</h1>

	@Html.Raw(Model.PostContent)


	@await Component.InvokeAsync("Comments", new { id = Convert.ToInt32(Context.Request.Query["id"]) })
</div>













