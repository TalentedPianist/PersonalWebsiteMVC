@{
}
@model PersonalWebsiteMVC.Areas.Photos.Models.PhotosViewModel

<div id="Photos">
    <h1>@Context.Request.Query["name"]</h1>

    @if (Model.PagedPhotos is not null)
    {
        foreach (var item in Model.PagedPhotos)
        {
            @item.Name
        }
    }
    else
    {
        <p>No photos have been found just now.  Please check back later.</p>
    }
</div>