@using PersonalWebsiteMVC.Models 
@model IEnumerable<Album>  

<div id="Albums">

    <section>
        <h1>Photo Albums</h1>

    </section>
    <section>
        @if (Model.Count() == 0)
        {
            <p>No albums have been found just now.  Please check back later.</p>
        }
        else
        {
            foreach (Album album in Model)
            {
                if (album.CoverPhoto is null)
                {
    <svg enable-background="new 4 8 40 32" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path d="m40 12h-18l-4-4h-10c-2.2 0-4 1.8-4 4v8h40v-4c0-2.2-1.8-4-4-4z" fill="#ffa000" /><path d="m40 12h-32c-2.2 0-4 1.8-4 4v20c0 2.2 1.8 4 4 4h32c2.2 0 4-1.8 4-4v-20c0-2.2-1.8-4-4-4z" fill="#ffca28" /></svg>
                }
            }
        }
    </section>
</div>