@{
}
@model PersonalWebsiteMVC.Areas.Photos.Models.PhotosViewModel

@TempData["Message"]

<div id="Photos">
    <section>
        <h1>@ViewBag.AlbumName</h1>

    </section>
    <section data-featherlight-gallery data-featherlight-filter="a">

        @foreach (var photo in Model.PagedPhotos!)
        {

                <figure>
                    <!-- Note to self: the href content is key to getting thifs working!!! -->
                    <a class="gallery" href="@photo.ImageUrl" data-name="@photo.Name"><img src="@photo.ImageUrl" data-id="@photo.Id" data-name="@photo.Name"></a>
                
                    <figcaption>@photo.Name</figcaption>
                    
                </figure>

        }

    </section>
    <section>
        @Html.PagedListPager((IPagedList)Model.PagedPhotos!, page => Url.Action("Index", "Album", new { pageNumber = page, area = "Photos", name = Context.Request.Query["name"], id = Context.Request.Query["id"] }),
new PagedListRenderOptions
{
    DisplayItemSliceAndTotal = true,
    LiElementClasses = new string[] { "page-item" },
    PageClasses = new String[] { "page-link" }
})
    </section>
</div>


<div id="photoModal">
    
</div>

@section Scripts {

    <script src="/lib/ckeditor5/ckeditor.min.js"></script>

    <script>
        $(function () {   
            $("a.gallery").featherlightGallery({
                // https://github.com/noelboss/featherlight/blob/master/test/featherlight_gallery_test.js
               
                afterContent: function () {
                    lastCurrent = this.$currentTarget[0];
                    let name = $(lastCurrent).data('name');
                    let src = $(lastCurrent).find('img').attr('src');
                    console.log(src);
                    this.$instance.find('.featherlight-content').html(`
                       <h1>${name}</h1>
                       <img src="${src}">
                 `);
                }
               
            });
        });
        
    </script>


}
