@{
}
@using PersonalWebsiteMVC.Models
@using PersonalWebsiteMVC.Areas.Photos.Models
@model PhotosViewModel

<div id="Albums">

    <section>
        <h1>Albums</h1>
        @ViewBag.Message
    </section>
    <section>
        @if (Model.PagedAlbums!.Count() == 0)
        {
            <p>No albums have been found just now. Please check back later.</p>
        }
        else
        {
            foreach (var album in Model.PagedAlbums!)
            {

                if (album.CoverPhoto is null)
                {
                    <figure>
                        <svg enable-background="new 4 8 40 32" xmlns="http://www.w3.org/2000/svg" viewBox="4 8 40 32">                             
                        <path d="m40 12h-18l-4-4h-10c-2.2 0-4 1.8-4 4v8h40v-4c0-2.2-1.8-4-4-4z" fill="#ffa000"></path>                             
                        <path d="m40 12h-32c-2.2 0-4 1.8-4 4v20c0 2.2 1.8 4 4 4h32c2.2 0 4-1.8 4-4v-20c0-2.2-1.8-4-4-4z" fill="#ffca28"></path>                         </svg>
                        <figcaption><a asp-action="Index" asp-controller="Photos" asp-area="Photos" asp-route-name="@album.Name">@album!.Name</a></figcaption>
                    </figure>
                }
                else
                {
                    <figure>
                        <img src="@album.CoverPhoto">
                        <figcaption><a asp-action="Index" asp-controller="Photos" asp-area="Photos" asp-route-name="@album.Name" asp-route-id="@album.Id">@album.Name</a></figcaption>
                    </figure>
                }
            }
        }
    </section>
    <device include="desktop">
        <section>
           @Html.PagedListPager((IPagedList)Model.PagedAlbums!, page => Url.Action("Index", "Photos", new { pageNumber = page, area = "Photos" }),
                new PagedListRenderOptions
                {
                    DisplayItemSliceAndTotal = true,
                    LiElementClasses = new string[] { "page-item" },
                    PageClasses = new String[] { "page-link" }
                })
        </section>
    </device>
</div>