@using Microsoft.AspNetCore.Components
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model PersonalWebsiteMVC.Areas.Photos.Models.PhotosViewModel

@TempData["Message"]

@{
    ViewData["Title"] = "Home Page";
    var data = new ImportMapDefinition(
    new Dictionary<string, string>
    {
{ "ckeditor5", "/lib/ckeditor5/ckeditor5.js" },
{ "ckeditor5/", "/lib/ckeditor5/" },
    }, null, null);
}

<div id="Photos">

    <h1>@ViewBag.AlbumName</h1>


    <section>

        @foreach (var photo in Model.PagedPhotos!)
        {

            <figure>
                <a class="gallery" href="/Gallery/@ViewBag.AlbumName/@photo.Name" data-featherlight-gallery
                    data-name="@photo.Name" data-album-id="@photo.AlbumID" data-photo-id="@photo.PhotoID"><img
                        src="@photo.ImageUrl" data-id="@photo.AlbumID" data-name="@photo.Name"></a>

                <figcaption>@photo.Name</figcaption>

            </figure>

        }

    </section>
    <section>
        <p>You are on page @Model.PagedPhotos.PageNumber of @Model.PagedPhotos.PageCount.</p>

        @Html.PagedListPager((IPagedList)Model.PagedPhotos!, page => Url.Action("Index", "Album", new { pageNumber =
        page, area = "Photos", name = Context.Request.Query["name"], id = Context.Request.Query["id"] }),
                new PagedListRenderOptions
                {
                    DisplayItemSliceAndTotal = false,
                    LiElementClasses = new string[] { "page-item" },
                    PageClasses = new String[] { "page-link" },
                    UlElementClasses = new[] { "pagination", "justify-content-center", "mt-3" },
                })
    </section>
</div>


<div id="mylightbox" class="hidden">
    <div id="lightbox-content">
        <img class="lightbox-image" src="" alt="">

        <p class="comment-status"></p>


        <div class="comments-container"></div>

        <div class="pagination-container"></div>

        <form method="post">

            <div>
                <label>Name:</label>
                <input name="txtName" id="name" placeholder="John Smith">
            </div>
            <div>
                <label>Email:</label>
                <input type="email" id="email" placeholder="john@johnsmith.com">
            </div>
            <div>
                <label>Website:</label>
                <input id="website" name="txtWebsite" placeholder="https://www.johnsmith.com">
            </div>
            <div>
                <label>Comment:</label>
                <textarea id="ckeditor1"></textarea>
            </div>

            <button type="submit">Comment</button>
        </form>
    </div>

</div>


@section Scripts {

    <script>

        $('a.gallery').featherlightGallery({
            galleryFadeIn: 100,
            galleryFadeOut: 300,
            beforeContent: function (e) {
                let content = this.$content;
                $(content).empty();
            },
            afterContent: function (e) {

                let target = this.$currentTarget[0];
                let pName = $(target).data('name');
                let albumId = $(target).data('album-id');
                console.log(albumId);
                let instance = this.$instance;
                //$(this.$instance).find('.featherlight-content').html('Hello World!');




                $.ajax({
                    method: "POST",
                    url: "/Album/GetPhoto",
                    data: { name: pName, albumID: albumId, imgHref: target.href },
                    async: false,
                    cache: false,
                    success: function (message) {
                        //console.log(message);
                        $(instance).find('.featherlight-content').html(`
            
                                        ${message}
                                    `);



                    },
                    error: function (error) {
                        console.log(error);
                    }
                });

                let ckElement = instance.find('#ckeditor1')[0];
                ClassicEditor.create(ckElement, {
                    licenseKey: 'GPL',
                    plugins: [window.CKEditorEssentials, window.CKEditorParagraph, window.CKEditorBold, window.CKEditorItalic, window.CKEditorFont]
                })
                    .then(editor => {
                        $("#commentForm").on('submit', function (e) {
                            e.preventDefault();

                            let name = $(instance).find('#name')[0]
                            let email = $(instance).find('#email')[0];
                            let website = $(instance).find('#website')[0];

                            let message = editor.getData();

                            let errors = [];

                            if (!name.validity.valid) {
                                $(name).parent().find('.error').text('Please enter your name.');
                                $(name).addClass('inputError');
                                errors.push("Please enter your name.");
                            } else {
                                $(name).parent().find('.error').text('');
                                $(name).removeClass('inputError');
                            }

                            if (!email.validity.valid) {
                                $(email).parent().find('.error').text('Please enter your email address.');
                                $(email).addClass('inputError');
                                errors.push("Please enter your email address.");
                            } else {
                                $(email).parent().find('.error').text('');
                                $(email).removeClass('inputError');
                            }

                            if (editor.getData() === '') {
                                $(".ck").parent().find('.error').text('Please enter a message.');
                                $(".ck").addClass('inputError');
                                errors.push("Please enter a message.");
                            } else {
                                $(".ck").parent().find('.error').text('');
                                $(".ck").removeClass('inputError');
                            }
                        });
                    })
                    .catch(error => {
                        console.log(error);
                    });
            }
        });



    </script>


}
