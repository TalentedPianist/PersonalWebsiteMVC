@{
}
@model PersonalWebsiteMVC.Areas.Photos.Models.PhotosViewModel

@TempData["Message"]

<div id="Photos">
    <section>
        <h1>@ViewBag.AlbumName</h1>

    </section>
    <section data-featherlight-gallery data-featherlight-filter="a">

        @foreach (var photo in Model.PagedPhotos!)
        {

                <figure>
                
                    <a class="gallery" href="#photoModal" data-id="@photo.Id" data-src="@photo.ImageUrl" data-name="@photo.Name"><img src="@photo.ImageUrl" data-id="@photo.Id" data-featherlight="@Comments(photo.ImageUrl!)"></a>
                
                    <figcaption>@photo.Name</figcaption>
                    
                </figure>

        }

    </section>
    <section>
        @Html.PagedListPager((IPagedList)Model.PagedPhotos!, page => Url.Action("Index", "Album", new { pageNumber = page, area = "Photos", name = Context.Request.Query["name"], id = Context.Request.Query["id"] }),
new PagedListRenderOptions
{
    DisplayItemSliceAndTotal = true,
    LiElementClasses = new string[] { "page-item" },
    PageClasses = new String[] { "page-link" }
})
    </section>
</div>

<div id="photoModal">
    
</div>


@functions {
    static IHtmlContent Comments(string src)
    {
        var fullHtml = $@"
            <h1>{src}</h1>
            <div class='form-group'>
                <label>Name:</label>
                <input name='txtName' placeholder='John Smith'>
            </div>
            <button type='submit' class='btn btn-primary'>Submit</button>
        ";
       
        return new HtmlString(fullHtml);
    }
}


@section Scripts {

    <script src="/lib/ckeditor5/ckeditor.min.js"></script>

    <script>
        $(function () {
 

            $('.gallery').featherlightGallery({
                previousIcon: '<<',
                nextIcon: '>>',
                galleryFadeIn: 300,
                openSpeed: 300,
                contentFilters: 'html'
            });

            
        });
        
    </script>


}
