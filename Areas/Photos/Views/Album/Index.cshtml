@{
}
@model PersonalWebsiteMVC.Areas.Photos.Models.PhotosViewModel


<div id="Photos">
    <section>
        <h1>@ViewBag.AlbumName</h1>
    </section>
    <section>

        @foreach (var photo in Model.PagedPhotos!)
        {
            <figure>
                <img src="/Gallery/@Context.Request.Query["name"]/@photo.Name" data-id="@photo.Id">
                <figcaption><a href="#photoElement" class="f1">@photo.Name</a></figcaption>
            </figure>
        }

    </section>
    <section>
        @Html.PagedListPager((IPagedList)Model.PagedPhotos!, page => Url.Action("Index", "Album", new { pageNumber = page, area = "Photos", name = Context.Request.Query["name"], id = Context.Request.Query["id"] }),
new PagedListRenderOptions
{
    DisplayItemSliceAndTotal = true,
    LiElementClasses = new string[] { "page-item" },
    PageClasses = new String[] { "page-link" }
})
    </section>
</div>

<div id="photoElement">

</div>




@section Scripts {


    <script>
        document.querySelector("#Photos section:nth-of-type(2)").querySelectorAll("figure").forEach(function (element, index) {
            let name = element.querySelector("figcaption").querySelector("a").innerText;
            let src = element.querySelector("img").getAttribute("src");
            let id = $(element).find('img').data('id');



            $(element).find("figcaption").find("a").on('click', function (e) {
                e.preventDefault();

                $.ajax({
                    method: "POST",
                    url: "@Url.Action("GetComments", "Comments")",
                    data: { 'id': id },
                    async: false,
                    cache: false,
                    success: function (message) {
                        console.log(message);


                        $("#photoElement").html(`
                            <img src="${src}">
                            <hr>
                            <div id="Comments">
                            <h3>Comments</h3>
                            ${message}
                            </div>
                            <form method="post">
                            <div>
                                <label for="name">Name:</label>
                                <input id="name" type="text" name="txtName">
                            </div>
                            <div>
                                <label for="email">Email:</label>
                                <input id="email" type="email" name="txtEmail">
                            </div>
                            <div>
                                <label for="website">Website:</label>
                                <input id="website" type="text" name="txtWebsite">
                            </div>
                            <div>
                                <label>Comment:</label>
                                <textarea id="ckeditor1" name="txtComment"></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary">Comment</button>
                        </form>

                        `);




                        $.featherlight('#photoElement',
                            {
                                close: function (e) {
                                    e.preventDefault();
                                    window.location.reload();
                                }
                        });
                    },
                    error: function (err) {
                        console.log(err);
                    }
                });
            });





 });




        function GetComments(id) {
            let result = undefined;

            return result;
        }


    </script>

    <script type="importmap">
        {
            "imports": {
                "ckeditor5": "https://cdn.ckeditor.com/ckeditor5/43.1.0/ckeditor5.js",
                "ckeditor5/": "https://cdn.ckeditor.com/ckeditor5/43.1.0/"
            }
        }
    </script>

    <script type="module">
        import {
            ClassicEditor,
            Essentials,
            Bold,
            Italic,
            Font,
            Paragraph
        } from 'ckeditor5';


        if (document.querySelector("#ckeditor1")) {
            ClassicEditor
                .create(document.querySelector('#ckeditor1'), {
                    plugins: [Essentials, Bold, Italic, Font, Paragraph],
                    toolbar: [
                        'undo', 'redo', '|', 'bold', 'italic', '|',
                        'fontSize', 'fontFamily', 'fontColor', 'fontBackgroundColor'
                    ]
                })
                .then( /* ... */)
                .catch( /* ... */);
        }
    </script>
}
