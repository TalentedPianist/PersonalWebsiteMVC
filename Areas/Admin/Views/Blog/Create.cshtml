@model PersonalWebsiteMVC.Models.Posts
@using PersonalWebsiteMVC.Data
@inject ApplicationDbContext db
@{
    ViewData["Title"] = "Create";
    Layout = "~/Areas/Admin/Shared/_Layout.cshtml";
}

<h1 class="bg-info text-white">Create</h1>
<a asp-action="Index" class="btn btn-secondary">Back</a>
<div asp-validation-summary="All" class="text-danger"></div>

@TempData["Message"]

<form method="post" id="createPost" asp-action="SavePost" asp-controller="Blog" asp-area="Admin" enctype="multipart/form-data" name="CreateForm">

    <div class="form-group">
        <label asp-for="PostContent">Content:</label>
        <!-- Note: textarea needs the name attribute or else data posted will be null -->
        <textarea asp-for="PostContent" id="ckeditor1" class="form-control border-black"></textarea>
    </div>
    <div class="form-group">
        <label asp-for="PostTitle">Title:</label>
        <input asp-for="PostTitle" class="form-control" id="title" />
    </div>
    <div class="form-group">
        <label class="form-label col-sm-2">Featured Image:</label>
        <input type="file" name="File1" class="form-control" id="image">
    </div>
    <div class="form-group">
        <label asp-for="PostPublished">Published:</label>
        <select asp-for="PostPublished" class="form-control border-black">
            <option value="true">Yes</option>
            <option value="false">No</option>
        </select>
    </div>
    <div class="form-group">
        <label asp-for="CategoryID">Category:</label>
        <select asp-for="CategoryID" class="form-control border-black" id="category">
            @foreach (var item in db.Categories)
            {
                <option value="@item.CategoryID" />
                @item.Category
            }
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
</form>

<a href="#" id="draft">Save Draft</a>


@section Scripts { 
    <script>
        $(function () {
            function GetDateTime() {
                var currentdate = new Date();
                var datetime = currentdate.getDate() + "/"
                    + (currentdate.getMonth() + 1) + "/"
                    + currentdate.getFullYear() + " "
                    + currentdate.getHours() + ":"
                    + currentdate.getMinutes() + ":"
                    + currentdate.getSeconds();
                return datetime;
            }


            $("#draft").on('click', function (e) {
                e.preventDefault();

                var formData = {
                    PostContent: $("#ckeditor1").val(),
                    PostTitle: $("#title").val(),
                    PostPublished: false,
                    PostDate: GetDateTime(),
                    CommentCount: 0,
                };
                console.log(formData);
                $.ajax({
                    method: "POST",
                    url: "@Url.Action("SaveDraft", "Blog")",
                    data: JSON.stringify(formData),
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    async: false,
                    cache: false,
                    processData: false,
                    success: function (message) {
                        console.log(message);
                    },
                    error: function (err) {
                        console.log(err);
                    }
                });
             
            });
        });
    </script>
}



