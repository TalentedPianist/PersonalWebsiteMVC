@model IEnumerable<Guestbook>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Shared/_Layout.cshtml";
}

<h1 class="bg-info text-white">Guestbook</h1>
<a asp-action="Create" class="btn btn-secondary">Create</a>

<table class="table">
     <tr><th>ID</th><th>User</th><th>Email</th><th>Update</th><th>Details</th><th>Delete</th></tr>
     @foreach (var item in Model)
     {
          <tr>
          <td>@item.Id</td>
          <td>@item.GuestbookAuthor</td>
          <td>@item.GuestbookAuthorEmail</td>
          <td><a asp-action="Update" class="btn btn-primary" asp-route-id="@item.Id">Update</a></td>
          <td><a asp-action="Details" class="btn btn-primary" asp-route-id="@item.Id">Details</a></td>
          <td><a asp-action="Delete" class="btn btn-primary" asp-route-id="@item.Id">Delete</a></td>
          </tr>
     }
</table>

