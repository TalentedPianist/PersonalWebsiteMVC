@{
    Layout = "~/Areas/Admin/Shared/_Layout.cshtml";
}
@model Album
@using Microsoft.AspNetCore.Hosting
@using Microsoft.AspNetCore.Http
@inject IWebHostEnvironment env
@inject IHttpContextAccessor http
@using HGO.ASPNetCore.FileManager.ViewComponentsModel 


<h1 class="bg bg-info p-1">Update Album</h1>
<a asp-action="Index" asp-area="Admin" asp-controller="Gallery" class="btn btn-secondary">Back</a>

@Html.Raw(TempData["Message"])

<form method="post" asp-action="UpdateAlbum" asp-area="Admin" asp-controller="Gallery" name="UpdateForm" enctype="multipart/form-data">
    <div class="form-group">
        <label>Name:</label>
        <input type="text" asp-for="Name" class="form-control">
    </div>
    <div class="form-group">
        <label>Description:</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>
    <div class="form-group">
        <label>Location:</label>
        <input type="text" asp-for="Location" class="form-control autocomplete">
    </div>
    <div class="form-group">
        <label>Cover Photo:</label>
        <input type="file" asp-for="CoverPhoto" name="coverPhoto" class="form-control">
    </div>
    <input type="hidden" name="AlbumID" value="@Model.Id">
    <button type="submit" class="btn btn-primary">Submit</button>
    <button type="button" class="btn btn-link" data-toggle="modal" data-target="#fileManager">Manage Photos</button>
</form>


<div class="modal fade" id="fileManager" tabindex="-1" role="dialog" aria-labelledby="fileManagerLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="fileManagerLabel">Modal title</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body border-0">
                @await Component.InvokeAsync("FileManagerComponent", new FileManagerModel()
           {
                Id = "FM1",
                RootFolder = System.IO.Path.Combine(env.ContentRootPath, "Gallery"),
                ApiEndPoint = Url.Action("HgoApi")!,
                Config = new FileManagerConfig()

           });
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>


@section Scripts { 
    <script async src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAleDWdvOSaSXhU1ppugKYwiehOQ8e0ZWM&loading=async&libraries=places&callback=initialize">
    </script>

    <script>

        function initialize() {
            const center = { lat: 50.064192, lng: -130.605469 };
            // Create a bounding box with sides ~10km away from the center point
            const defaultBounds = {
                north: center.lat + 0.1,
                south: center.lat - 0.1,
                east: center.lng + 0.1,
                west: center.lng - 0.1,
            };
            const input = document.querySelector(".autocomplete");
            const options = {
                bounds: defaultBounds,
                componentRestrictions: { country: "uk" },
                fields: ["address_components", "geometry", "icon", "name"],
                strictBounds: false,
            };
            const autocomplete = new google.maps.places.Autocomplete(input, options);
        }
    </script>
}