@{
    Layout = "~/Areas/Admin/Shared/_Layout.cshtml";
}
@model Album
@using HGO.ASPNetCore.FileManager.ViewComponentsModel
@inject IWebHostEnvironment _env 

<h1 class="bg bg-info p-1">Create Album</h1>
<a asp-action="Index" asp-area="Admin" asp-controller="Gallery" class="btn btn-secondary">Back</a>


<form method="post" asp-action="CreateAlbum" asp-controller="Gallery" asp-area="Admin">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="form-group">
        <label>Name:</label>
        <input type="text" asp-for="Name" class="form-control">
    </div>
    <div class="form-group">
        <label>Description:</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>
    <div class="form-group">
        <label>Location:</label>
        <input type="text" asp-for="Location" class="form-control autocomplete">
    </div>
    <div class="form-group">
        <label>Cover Photo:</label>
        <input type="file" asp-for="CoverPhoto" class="form-control">
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
    <a href="#" data-toggle="modal" data-target=".modal">Add Photos</a>
</form>

<div class="modal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Modal title</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">

                @await Component.InvokeAsync("FileManagerComponent", new FileManagerModel()
                {
                    Id = "FM1",
                    RootFolder = System.IO.Path.Combine(_env.ContentRootPath, "Gallery"),
                    ApiEndPoint = Url.Action("HgoApi")!,
                    Config = new FileManagerConfig()
                });

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {


    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAleDWdvOSaSXhU1ppugKYwiehOQ8e0ZWM&libraries=places&loading=async&callback=initialize"></script>
    <script>
        function initialize() {
            const center = { lat: 50.064192, lng: -130.605469 };
            // Create a bounding box with sides ~10km away from the general point
            const defaultBounds = {
                north: center.lat + 0.1,
                south: center.lat - 0.1,
                east: center.lng + 0.1,
                west: center.lng - 0.1,
            };
            const input = document.querySelector(".autocomplete");
            const options = {
                bounds: defaultBounds,
                componentRestrictions: { country: "uk" },
                fields: ["address_components", "gemoetry", "icon", "name"],
                strictBounds: false,
            };
            const autocomplete = new google.maps.places.Autocomplete(input, options);
        }
    </script>

    <script>

    </script>
}