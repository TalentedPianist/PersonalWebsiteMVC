@model PagedList<Comments> 
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Shared/_Layout.cshtml";
}
@using X.PagedList
@using X.PagedList.Extensions
@using X.Web.PagedList

<h1 class="bg-info text-white">Comments</h1>
<a asp-action="Create" class="btn btn-secondary">Create</a>

<table class="table">
     <tr><th></th><th>CommentID</th><th>BlogID</th><th>User</th><th>Comment Type<th>Update</th><th>Details</th><th>Delete</th></tr>
     @foreach (var item in Model)
     {
          <tr>
          <td><input type="checkbox" name="delete" value="@item.CommentID"></td>
          <td>@item.CommentID</td>
          <td>@item.PostID</td>
          <td>@item.CommentAuthor</td>
          <td>@item.CommentType</td>
          <td><a asp-action="Update" class="btn btn-primary" asp-route-id="@item.CommentID">Update</a></td>
          <td><a asp-action="Details" class="btn btn-primary" asp-route-id="@item.CommentID">Details</a></td>
          <td><a asp-action="Delete" class="btn btn-primary" asp-route-id="@item.CommentID">Delete</a></td>
          </tr>
     }
</table>


@Html.PagedListPager((IPagedList)Model, page => Url.Action("Index", new { pageNumber = page }),
    new PagedListRenderOptions
    {
        DisplayItemSliceAndTotal = true,
        LiElementClasses = new string[] { "page-item" },
        PageClasses = new string[] { "page-link" }
    })


<a href="#" id="delete">Delete</a>

@section Scripts { 
    <script>
        let del = [];
        [].forEach.call(
            document.querySelectorAll('input[type="checkbox"]'),
            function (cb) {
                cb.addEventListener('click', function (e) {
                    del.push({ 'CommentID': cb.value });
                });
            }
        );
        $(function () {
            $("#delete").on('click', function (e) {
                e.preventDefault();
                $.ajax({
                    method: "POST",
                    url: "@Url.Action("DeleteMultiple", "Comments")",
                    data: JSON.stringify(del),
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    cache: false,
                    async: false,
                    success: function (message) {
                        console.log(message);
                        window.location.reload();
                    },
                    error: function (err) {
                        console.log(err);
                    }
                });
            });
        });
    </script>
}
