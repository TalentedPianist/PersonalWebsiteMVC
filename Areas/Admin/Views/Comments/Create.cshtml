@model Comments
@inject ApplicationDbContext db 
@{
    ViewData["Title"] = "Create";
    Layout = "~/Areas/Admin/Shared/_Layout.cshtml";
}

<h1 class="bg-info text-white">Create</h1>
<a asp-action="Index" class="btn btn-secondary">Back</a>
<div asp-validation-summary="All" class="text-danger"></div>

<form method="post">
     <div class="form-group">
          <label asp-for="CommentContent">Comment:</label>
          <textarea rows="10" cols="30" asp-for="CommentContent" class="form-control" id="comment"></textarea>
     </div>
     <div class="form-group">
          <label asp-for="PostID">Blog:</label>
          <select asp-for="PostID" class="form-control" id="post">
               @foreach (var item in db.Posts)
               {
                    <option value="@item.PostID">@item.PostTitle</option>
               }
          </select>
     </div>
     <div class="form-group">
          <label asp-for="CommentAuthor">Name:</label>
          <input asp-for="CommentAuthor" class="form-control" id="name" />
     </div>
     <div class="form-group">
          <label asp-for="CommentAuthorEmail">Email:</label>
          <input asp-for="CommentAuthorEmail" class="form-control" id="email" />
     </div>
     <div class="form-group">
          <label asp-for="CommentAuthorUrl">Website:</label>
          <input asp-for="CommentAuthorUrl" class="form-control" id="website" />
     </div>
     <button type="submit" class="btn btn-primary">Save</button>
</form>

<a href="#" id="draft">Save Draft</a>


@section Scripts { 
   <script>
       $(function () {
           $("#draft").on('click', function (e) {
               e.preventDefault();

               var formData = {
                   PostID: $("#post").val(),
                   CommentAuthor: $("#name").val(),
                   CommentAuthorEmail: $("#email").val(),
                   CommentContent: $("#comment").val(),
                   CommentAuthorIP: "@Context.Connection.RemoteIpAddress!.ToString()",
                   CommentDate: "@DateTime.Now",
                   CommentType: "Post"
               };
               //console.log(formData);
               $.ajax({
                   method: "POST",
                   url: "@Url.Action("SaveDraft", "Comments")",
                   data: JSON.stringify(formData),
                   headers: {
                       'Content-Type': 'application/json'
                   },
                   async: false,
                   cache: false,
                   processData: false,
                   success: function (message) {
                       console.log(message);
                   },
                   error: function (err) {
                       console.log(err);
                   }
               });
           });
       });
   </script>
}
