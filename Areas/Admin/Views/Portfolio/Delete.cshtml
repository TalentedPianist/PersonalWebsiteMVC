@{
}
@model Portfolio

<h1 class="bg bg-info p-1">Delete</h1>
<a class="btn btn-secondary" asp-action="Index" asp-controller="Portfolio" asp-area="Admin">Back</a>

<form method="post" asp-action="DeletePortfolio" asp-controller="Portfolio" asp-area="Admin">
<p>Are you sure you want to delete portfolio item @Model.Name?</p>
<input type="hidden" name="portfolioID" value="@Model.PortfolioID">
<button type="submit" class="btn btn-danger">Yes</button>
</form>

