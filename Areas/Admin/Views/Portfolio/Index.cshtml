@{
}
@model List<Portfolio>

<h1 class="bg bg-info">Portfolio</h1>
<a asp-action="Create" asp-area="Admin" asp-controller="Portfolio" class="btn btn-secondary">Create</a>

@if (Model.Count() == 0)
{
     <p>No items found just now.  Please check back later.</p>
}
else
{
     <table>
          <thead>
               <tr>
                    <th>Name</th>
                    <th>Url</th>
                    <th>Update</th>
                    <th>Details</th>
                    <th>Delete</th>
               </tr>
          <tbody>
               @foreach (Portfolio item in Model)
               {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Url</td>
                        <td><a asp-action="Update" asp-area="Admin" asp-controller="Portfolio" asp-route-id="@item.PortfolioID" class="btn btn-primary">Update</a></td>
                        <td><a asp-action="Details" asp-area="Admin" asp-controller="Portfolio" asp-route-id="@item.PortfolioID" class="btn btn-primary">Details</a></td>
                        <td><a asp-action="Delete" asp-area="Admin" asp-controller="Portfolio" asp-route-id="@item.PortfolioID" class="btn btn-primary">Delete</a></td>
                    </tr>
               }
          </tbody>
     </table>
}