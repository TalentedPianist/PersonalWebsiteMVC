@{
}
@model Portfolio

<h1 class="bg bg-info">Create</h1>
<a asp-action="Index" asp-controller="Portfolio" asp-area="Admin" class="btn btn-secondary">Back</a>


<form method="post" asp-action="AddPortfolio" asp-controller="Portfolio" asp-area="Admin">
    <div asp-validation-summary="All"></div>

    <div>
        <label asp-for="Name">Name:</label>
        <input asp-for="Name" class="form-control">
    </div>
    <div>
        <label asp-for="Url">Url:</label>
        <input asp-for="Url" class="form-control">
    </div>
    <div>
        <label asp-for="ImageUrl">Image Url:</label>
        <input asp-for="ImageUrl" class="form-control">
    </div>
    <div>
        <label asp-for="Description">Description:</label>
        <textarea id="ckeditor1" class="form-control"></textarea>
    </div>
    <div>
        <label asp-for="Keywords">Keywords:</label>
        <input asp-for="Keywords" class="form-control">
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
</form>