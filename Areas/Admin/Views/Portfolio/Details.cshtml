@{
}
@model Portfolio

<h1 class="bg bg-info">Portfolio Details</h1>
<a class="btn btn-secondary" asp-action="Index" asp-controller="Portfolio" asp-area="Admin">Back</a>

<dl>
    <dt>ID:</dt>
    <dd>@Model.PortfolioID</dd>
    <dt>Name:</dt>
    <dd>@Model.Name</dd>
    <dt>Url:</dt>
    <dd>@Model.Url</dd>
    <dt>Description:</dt>
    <dd>@Html.Raw(Model.Description)</dd>
    <dt>Date Created:</dt>
    <dd>@Model.DateCreated</dd>
    <dt>IP Address:</dt>
    <dd>@Model.IP</dd>
    <dt>User:</dt>
    <dd>@Model.User</dd>
</dl>

<a class="btn btn-link" asp-action="Update" asp-controller="Portfolio" asp-area="Admin">Update</a> 
|
<a class="btn btn-link" asp-action="Delete" asp-controller="Portfolio" asp-area="Admin" asp-route-id="@Model.PortfolioID">Delete</a>
