@{
}
@model List<SearchModel>


<h1 class="bg bg-info">Search</h1>
<a asp-action="Create" asp-area="Admin" class="btn btn-secondary">Create</a>

@TempData["Message"]

@if (Model is not null)
{
	<table class="table table-bordered">
		<thead>
			<tr>
				<th>ID</th>
				<th>Title</th>
			</tr>
		</thead>
		<tbody>
			@foreach (SearchModel item in Model)
			{
				<tr>
					<td>@item.Id</td>
					<td>@item.Title</td>
					<td><a asp-action="Update" asp-controller="Search" asp-area="Admin" asp-route-id="@item.Id" class="btn btn-primary">Update</a></td>
					<td><a asp-action="Details" asp-controller="Search" asp-area="Admin" asp-route-id="@item.Id" class="btn btn-primary">Details</a></td>
					<td><a asp-action="Delete" asp-controller="Search" asp-area="Admin" asp-route-id="@item.Id" class="btn btn-primary">Delete</a></td>

				</tr>
			}
		</tbody>
	</table>
}
else
{
	<p>Delete all documents from Solr?</p>
	<form method="post" asp-action="DeleteAll" asp-controller="Search" asp-area="Admin">
		<button type="submit" class="btn btn-primary">Yes</button>
	</form>
}
