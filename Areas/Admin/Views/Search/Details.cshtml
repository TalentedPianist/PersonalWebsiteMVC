@{
}
@model SearchModel

<h1 class="bg bg-info">Details</h1>
<a class="btn btn-secondary" asp-action="Index" asp-controller="Search" asp-area="Admin">Back</a>

<dl>
    <dt>ID:</dt>
    <dd>@Model.Id</dd>
    <dt>Title:</dt>
    <dd>@Model.Title</dd>
    <dt>Link:</dt>
    <dd>@Model.Link</dd>
    <dt>Body:</dt>
    <dd>@Html.Raw(Model.Body)</dd>
</dl>

<a class="btn btn-link" asp-action="Update" asp-controller="Search" asp-area="Admin" asp-route-id="@Model.Id">Update</a> 
|
<a class="btn btn-link" asp-action="Delete" asp-controller="Search" asp-area="Admin" asp-route-id="@Model.Id">Delete</a>