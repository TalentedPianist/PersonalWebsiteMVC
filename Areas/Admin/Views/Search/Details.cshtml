@{
     Layout = "~/Areas/Admin/Shared/_Layout.cshtml";
}
@model SearchModel

<h1 class="bg bg-info">Details</h1>
<a class="btn btn-secondary" asp-action="Index" asp-controller="Search" asp-area="Admin">Back</a>

<dl>
    <dt>ID:</dt>
    <dd>@Model.Id</dd>
    <dt>Title:</dt>
    <dd>@Model.Title</dd>
    <dt>Url:</dt>
    <dd>@Model.Url</dd>
    <dt>Body:</dt>
    <dd>@Model.Body</dd>
</dl>
