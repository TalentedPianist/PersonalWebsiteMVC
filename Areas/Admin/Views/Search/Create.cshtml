@{
    Layout = "~/Areas/Admin/Shared/_Layout.cshtml";
}
@using HtmlAgilityPack

<h1 class="bg bg-info p-1">Create</h1>
<a asp-action="Index" asp-controller="Search" asp-area="Admin">Back</a>



@functions { 
    private string ParseHtml(string url)
    {
        var web = new HtmlWeb();
        var doc = web.Load(url);
        var node = doc.DocumentNode.SelectSingleNode("//head/title");
        return node.OuterHtml;
    }
}


@section Scripts { 
    
    <script>
        console.log("Hello World!");
    </script>
}