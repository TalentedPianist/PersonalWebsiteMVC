@{
    Layout = "~/Areas/Admin/Shared/_Layout.cshtml";
}
@using HtmlAgilityPack
@using System.Text
@model SearchModel

<h1 class="bg bg-info p-1">Create</h1>
<a asp-action="Index" asp-controller="Search" asp-area="Admin" class="btn btn-secondary">Back</a>

@TempData["Message"]





<form method="post" asp-action="CreateIndex" asp-controller="Search" asp-area="Admin">
    <div>
        <label>URL:</label>
        <input name="Url" asp-for="Url" class="form-control">
    </div>
    <button class="btn btn-primary" type="submit">Submit</button>
</form>


