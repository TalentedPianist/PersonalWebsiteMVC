@model PagedList<IdentityRole>
@using PersonalWebsiteMVC.CustomTagHelpers
@using X.PagedList
@using X.PagedList.Extensions
@using X.Web.PagedList 

@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Shared/_Layout.cshtml";
}

<h1 class="bg-info text-white">Roles</h1>
<a asp-action="Create" class="btn btn-secondary">Create a Role</a>

<table class="table table-sm table-bordered table-bordered">
     <tr><th>ID</th><th>Name</th><th>Users</th><th>Update</th><th>Details</th><th>Delete</th></tr>
     @foreach (var role in Model)
     {
          <tr>
          <td>@role.Id</td>
          <td>@role.Name</td>
          <td i-role="@role.Id"></td>
          <td><a class="btn btn-sm btn-primary" asp-action="Update" asp-route-id="@role.Id">Update</a></td>
          <td><a class="btn btn-sm btn-primary" asp-action="Details" asp-route-id="@role.Id">Details</a></td>
          <td><a class="btn btn-sm btn-primary" asp-action="Delete" asp-route-id="@role.Id">Delete</a></td>
          </tr>
     }
</table>

@Html.PagedListPager((IPagedList)Model, page => Url.Action("Index", "Roles", new { pageNumber = page, area = "Admin" }),
    new PagedListRenderOptions
    {
        DisplayItemSliceAndTotal = true,
        LiElementClasses = new string[] { "page-item" },
        PageClasses = new string[] { "page-link" }
    })

