@{
    Layout = "~/Areas/Admin/Shared/_Layout.cshtml";
}
@model Photos

@TempData["Message"]

<h1 class="bg bg-info p-1">Delete</h1>
<a asp-action="Index" asp-route-album="@Context.Request.Query["album"]" class="btn btn-link">Back</a>

<form method="post" asp-action="DeletePhoto">
    <p>Are you sure you want to delete photo <b>@Model.Name</b> from the database?</p>
    <input type="hidden" asp-for="Id" value="@Model.Id">
    <button type="submit" class="btn btn-primary">Yes</button>
</form>

