@{
    Layout = "~/Areas/Admin/Shared/_Layout.cshtml";
}
@model IEnumerable<Photos>
<h1 class="bg bg-info p-1 text-white">Photos for @ViewBag.AlbumName</h1>

@ViewBag.Message

@{
    if (ViewBag.Files.Count == 0)
    {
        <form method="post" asp-action="AddFiles" enctype="multipart/form-data" asp-controller="Photos" asp-area="Admin">
            <div class="form-group">
                <label for="Files">Select Files:</label>
            <input type="file" class="form-control" multiple>
            </div>
    }
}
