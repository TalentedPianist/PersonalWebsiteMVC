@{
    Layout = "~/Areas/Admin/Shared/_Layout.cshtml";
}

@using Microsoft.AspNetCore.Hosting
@inject IWebHostEnvironment _env
@inject ApplicationDbContext _db
@using X.PagedList.Mvc.Core
@using X.PagedList

<h1 class="bg bg-info p-1 text-white">Photos for @ViewBag.AlbumName</h1>

@TempData["Message"]

@{
    try
    {
        var path = System.IO.Path.Combine(_env.ContentRootPath, "Gallery", ViewBag.AlbumName);
        var files = Directory.GetFiles(path);
        int count = Directory.GetFiles(path, "*", SearchOption.AllDirectories).Length;
        if (count == 0)
        {
            <p>No files exist for this album. Add files?</p>
            <form method="post" asp-action="AddFiles" asp-controller="Photos" asp-area="Admin" enctype="multipart/form-data">
                <div class="form-group">
                    <label for="Files">Add Files</label>
                    <input type="file" name="AddFiles" class="form-control-sm" multiple>
                </div>
                <input type="hidden" name="AlbumID" value="@ViewBag.AlbumID">
                <button type="submit" class="btn btn-primary">Add</button>
            </form>
        }


        <div id="Gallery">
            @{
                try
                {
                    foreach (FileInfo file in ViewBag.OnePageOfFiles)
                    {
                        //var url = $"/Gallery/{ViewBag.AlbumName}/{file.Name}"
                       

                        <figure>
                            <img id="thumbnail" src="@url" data-name="@file.Name" title="@file.Name">
                            <div>

                            </div>
                            @if (IsInDb(file.Name))
                            {
                                if (GetPicId(file.Name) > 0)
                                {
                                    <div>
                                        <a href="#" data-name="@file.Name" data-album="@ViewBag.AlbumName">View</a>
                                        <a asp-action="Update" asp-route-id="@GetPicId(file.Name)" asp-route-album="@ViewBag.AlbumID" asp-controller="Photos" asp-area="Admin">Update</a>
                                        <a asp-action="Details" asp-route-id="@GetPicId(file.Name)" asp-route-album="@ViewBag.AlbumID" asp-controller="Photos" asp-area="Admin">Details</a>
                                        <a asp-action="Delete" asp-route-id="@GetPicId(file.Name)" asp-route-album="@ViewBag.AlbumID" asp-controller="Photos" asp-area="Admin">Delete</a>
                                    </div>


                                }
                                else
                                {

                                }
                            }
                            <figcaption>
                                @file.Name

                            </figcaption>
                        </figure>

                    }
                }
                catch (NullReferenceException)
                {
                }
            }


        </div>



    }
    catch (DirectoryNotFoundException ex)
    {
        @ex.Message
        <p>Directory does not exist. Create it?</p>
        <form method="post" asp-action="CreateFolder" asp-controller="Gallery" asp-area="Admin">
            <input type="hidden" name="GalleryID" value="@ViewBag.GalleryID">
            <button type="submit" class="btn btn-primary">Yes</button>
        </form>
    }
}

<div id="DbLinks">
    <a href="#" id="AddToDb">Add to Database</a> |
    <a href="#" id="DelFromDb">Delete from Database</a>
</div>

<!--

    In order to get this working I had to disable endpoint routing in Program.cs and add app.UseMvc and map the route to the area.  There is also a bug in X.PagedList as described below.
   https://github.com/dncuug/X.PagedList/issues/133

-->

@Html.PagedListPager((IPagedList)ViewBag.OnePageOfFiles, page => Url.Action("Index", "Photos", new
{
    pageNumber = page,
    area = "Admin",
    id = ViewBag.AlbumID
}), new PagedListRenderOptions
{
    PageClasses = new string[] { "page-link" },
    UlElementClasses = new string[] { "pagination" },
    LiElementClasses = new string[] { "page-item" },
    DisplayItemSliceAndTotal = true,
});

<div class="modal fade" id="myModal" data-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel"
     aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"></h5>
            </div>
            <div class="modal-body">
                <img src="" alt="" id="image">
                <div id="IsInDb">
                    <a href="#" id="AddToDb">Add to Database</a>
                    <a href="#" id="DelFromDb">Delete from Database</a>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@functions {
    bool IsInDb(string name)
    {
        var exist = _db.Photos.Any(p => p.Name == name);
        if (!exist)
            return false;
        else
            return true;
    }

    int GetPicId(string name)
    {
        var pic = _db.Photos.Where(p => p.Name == name).FirstOrDefault();
        return pic!.Id;
    }
}


@section Scripts {
    <script>

        $(function () {

            function GetId(name) {
                let result = undefined;
                $.ajax({
                    method: "POST",
                    url: "@Url.Action("GetPicId", "Photos")",
                    data: {
                        'name': name,
                    },
                    async: false,
                    cache: false,
                    success: function (message) {
                        result = message;
                    },
                    error: function (err) {
                        console.log(err);
                    }
                });
                return result;
            }

            function CheckDb(name) {
                var result = false;
                $.ajax({
                    method: "POST",
                    url: "@Url.Action("AjaxDbCheck", "Photos")",
                    data: { 'name': name },
                    cache: false,
                    async: false,
                    success: function (message) {
                        //console.log(message);
                        result = message;
                    },
                    error: function (err) {
                        //console.log(err);
                    }
                });
                return result;
            }




            $("#Gallery figure").each(function (index, value) {
                let strName = $(value).find("img").data('name');
                let src = $(value).find("img").attr('src');
                let album = $(value).find("a").data('album');
                let open = $(value).find("a:first-child");
                let confirm = undefined;

                $(open).on('click', function (event) {
                    event.preventDefault();
                    $("#myModal").modal('show');
                    $("#myModal").on('shown.bs.modal', function () {
                        $("#myModal").find('.modal-header').html(`<h3>${strName}</h3>`);
                        $("#myModal").find('.modal-body').find('img').attr('src', src);

                        $("#myModal").find("#AddToDb").hide();
                        $("#myModal").find("#DelFromDb").hide();

                        if (CheckDb(strName) === false) {
                            $("#myModal").find("#AddToDb").show();
                        } else {
                            $("#myModal").find("#DelFromDb").show();
                        }

                        $("#myModal").find("#AddToDb").on('click', function (event) {
                            if (AddToDb(strName) === true) {
                                $("#AddToDb").hide();
                                $("#DelFromDb").show();
                            }
                        });
                        $("#myModal").find("#DelFromDb").on('click', function (event) {
                            if (DelFromDb(strName) === true) {
                                $("#DelFromDb").hide();
                                $("#AddToDb").show();
                            }

                        });
                    });
                });



                if (CheckDb(strName) === true) {
                    $(value).find("div:nth-of-type(1)").html(`
                        <p>Is in database</p>
                        <input type="checkbox" value="${strName}">
                    `);
                } else {
                    $(value).find("div:nth-of-type(1)").html(`
                        <p>Not in database</p>
                        <input type="checkbox" value="${strName}">
                    `);
                }


                $(this).on('mouseenter', function (e) {
                    e.preventDefault();
                    $(value).find("#DbCheck").addClass("overlay");
                    $(value).find("div:nth-of-type(1)").css("display", "flex");
                    $(value).find("div:nth-of-type(1)").addClass("overlay");
                });

                $(this).on('mouseleave', function (e) {
                    e.preventDefault();
                    $(value).find("div:nth-of-type(1)").css("display", "none");
                    $(value).find("div:nth-of-type(1)").removeClass("overlay");
                });


            });

            var add = [];
            var del = [];

            // After spending a whole night on this, the conclusion is that it needs to be done in plain old JavaScript insted of jQuery.  With jQuery I am limited to variables inside event handlers where is JS lets me do exactly what I want.  This should be very easy so I'm surprised its so difficult in jQuery.
            let cb = document.querySelectorAll("figure");
            cb.forEach(function (item, index) {


                item.addEventListener('click', function (event) {

                    //event.preventDefault();
                    // Here we don't use event.preventDefault() as that simply makes checkbox click not work.  Basics.
                    let confirm = item.querySelector("div").querySelector("p").innerHTML;
                    let value = item.querySelector("input").getAttribute("value");
                    let img = document.querySelector("#Gallery figure").querySelector("img").getAttribute("src");

                    if (confirm === "Is in database") { // Wasn't working because a really simple string character was missing.
                        let id = GetId(value);
                        del.push({ 'Id': id, 'Name': item.getAttribute("value") });
                    } else {
                        add.push({ 'Name': value, 'AlbumID': @ViewBag.AlbumID, 'ImageUrl': img });
                    }
                

                });

            });

            $("#AddToDb").on('click', function (e) {
                // Here we create an ajax request to add the selected checkbox values to the database.  We don't even have to use a separate function as this is handled by a click event.  It's that simple.
                $.ajax({
                    method: "POST",
                    url: "@Url.Action("AddMultipleToDb", "Photos")",
                    data: JSON.stringify(add), // Data was always null here because of incorrect syntax use.  JSON.stringify(add) is the correct way to achieve this.
                    headers: {
                        'Content-type': 'application/json',
                    },
                    async: false,
                    cache: false,
                    success: function (message) {
                        console.log(message);
                        window.location.reload(); // Needed since we are just trying to update the page with ajax and don't need a server side redirect.
                    },
                    error: function (err) {
                        //console.log(err);
                    }
                });
            });

            $("#DelFromDb").on('click', function (event) {
                event.preventDefault();
                $.ajax({
                    method: "POST",
                    url: "@Url.Action("RemoveMultipleFromDb", "Photos")",
                    data: JSON.stringify(del),
                    headers: {
                        'Content-type': 'application/json',
                    },
                    async: false,
                    cache: false,
                    success: function (message) {
                        console.log(message);
                        window.location.reload(); // Needed since we are just trying to update page data with ajax and don't need server side redirect.
                    },
                    error: function (err) {
                        console.log(err);
                    }
                });
            });



        });


    </script>
}
