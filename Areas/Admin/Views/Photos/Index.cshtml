			function DelImg(name) {
				$.ajax({
					method: "POST",
					url: "@Url.Action("RemoveFromDb", "Photos", new { album = ViewBag.AlbumName})",
					data: { 'name': name },
					async: false,
					cache: false,
					success: function (message) {
						console.log(message);
					},
					error: function (err) {
