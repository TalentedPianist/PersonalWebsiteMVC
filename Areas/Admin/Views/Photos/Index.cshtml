					error: function (err) {
						console.log(err);
					}
				});
				if (response.responseText == false) {
					
				} else {
					
				}
				

			}

			$("#DelImg").on('click', function (e) {
				e.preventDefault();
				console.log('Link was clicked!');
			});


			$("#Gallery figure").each(function (index, value) {

				$(this).find("a").on('click', function (e) {
					let name = $(value).find("img").data('name');
					let src = $(value).find("img").attr('src');
					let album = $(value).find("a").data('album');

					$("#ex1").html(`
						<h2>${name}</h2>
						<img src="${src}" alt="${name}">
						<a href="#" id="DelImg">Delete from Database</a>
