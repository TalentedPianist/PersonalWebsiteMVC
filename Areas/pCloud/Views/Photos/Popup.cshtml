	For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model ContentItem
@inject IConfiguration _config

@TempData["Message"]


@if (Model is not null)
{
	<h1>@Model.name</h1>

	<a href="#" id="coverPic">Make Cover Photo</a>


	<img src='@GetThumbs(Model.fileid!, "600x400")'>


	<ul>
		<li><a asp-action="Update" asp-controller="Photos" asp-area="pCloud" asp-route-id="@Model.fileid" class="btn btn-primary">Update</a></li>
		<li><a asp-action="Details" asp-controller="Photos" asp-area="pCloud" asp-route-id="@Model.fileid" class="btn btn-primary">Details</a></li>
		<li><a asp-action="Delete" asp-controller="Photos" asp-area="pCloud" asp-route-id="@Model.fileid" class="btn btn-primary">Delete</a></li>
	</ul>
}


@functions {
    string GetThumbs(string fileid, string size)
    {
	    var client = new RestClient("https://eapi.pcloud.com/");
	    var request = new RestRequest("getthumblink");
	    request.AddParameter("access_token", _config["PCloud:Local:AccessToken"]);
	    request.AddParameter("fileid", fileid);
	    request.AddParameter("size", size);
	    var response = client.Execute(request);
	    var result = JsonConvert.DeserializeObject(response.Content!);
	    JToken json = JToken.Parse(result!.ToString()!);
	    var url = "https://" + json["hosts"]![0] + json["path"];
	    return url;
    }
}
