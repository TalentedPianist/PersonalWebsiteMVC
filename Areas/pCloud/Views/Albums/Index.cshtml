@using System.Net.Http
@using System.Text.Json
@using System.Text.Json.Serialization
@using PersonalWebsiteMVC.Areas.pCloud.Models
@using Microsoft.AspNetCore.Http
@using RestSharp
@using Newtonsoft.Json
@using PersonalWebsiteMVC.Models
@inject IHttpClientFactory _httpClientFactory

<h1 class="bg bg-info p-1">Albums</h1>

<form method="post" asp-action="Auth" asp-controller="Photos">
	<button class="btn btn-link">Login to pCloud</button>
</form>
@Context.Session.GetString("PCloudToken")

<div id="Gallery">
	<ul>

		<li><a href="#" id="selectAll">Select All</a></li>
		<li><a href="#" id="addToDb">Add to Database</a></li>
		<li><a href="#" id="delFromDb">Delete from Database</a></li>
	</ul>
	<section>
	</section>
	<section>
	</section>
</div>



@section Scripts {
	<script>
		let add = [];
		let del = [];

		// JS for selecting all checkboxes
		$("#selectAll").on('click', function (e) {
			$("#Gallery section:nth-of-type(1)").find("figure").find("figcaption").find("input[type='checkbox']").each(function (index, item) {
				$(item).prop('checked', true);
			});

			$('input:checkbox:checked').map(function () {
				// Check if album is in database before doing anything else
				let name = this.value;
				$.getJSON("/pCloud/Albums/CheckInDb", { name: name }, function (message) {
					console.log(message);
					if (message === true) {
						// If album is in database, get ID using JSON
						$.ajax({
							method: "POST",
							url: "/pCloud/Albums/GetID",
							data: { name: name },
							async: false,
							cache: false,
							success: function (message) {
								console.log(message);
								if (message) {
									// Album is in database, add album to del array
									del.push({ 'AlbumID': message });
								} else {
									// Album is not in database, push to add array
									add.push({ 'Name': name });
								}
							},
							error: function (error) {
								console.log(error);
							}
						});

					} else {
						add.push({ 'Name': name });

					}
				});
			}).get();
		});


		$("#addToDb").on('click', function (e) {
			e.preventDefault();
			//console.log(add);

			$.ajax({
				url: "/pCloud/Albums/AddMultipleAlbumsToDb",
				method: "POST",
				contentType: "application/json",
				data: JSON.stringify(add),
				async: false,
				cache: false,
				success: function (message) {
					console.log(message);
				},
				error: function (error) {
					console.log(error);
				}
			});

		});

		$("#delFromDb").on('click', function (e) {
			$.ajax({
				url: "/pCloud/Albums/DelMultipleFromDb",
				method: "POST",
				contentType: "application/json",
				data: JSON.stringify(del),
				async: false,
				cache: false,
				success: function (message) {
					console.log(message);
				},
				error: function (error) {
					console.log(error);
				}
			});
		});

	</script>


	

}