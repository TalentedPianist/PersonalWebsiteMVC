<div id="Gallery">
     @if (Model is not null)
     {
          <section>
               @foreach (ContentItem item in Model)
               {
                    string thumb = default!;
                    var album = _db.Albums.Where(a => a.Name == item.name).FirstOrDefault();
                    if (album is not null)
                    {
                         if (album.CoverPhoto is not null)
                         {
                              thumb = GetThumbs(album.CoverPhoto, "600x400");

                         }
                    }
                    <figure>
                         <input type="checkbox" value="@item.name" data-date="@item.created">
                         @if (thumb is not null)
                         {
                              <img src="@thumb">
                         }
                         else
                         {

                              <svg enable-background="new 4 8 40 32" viewBox="4 8 40 32" xmlns="http://www.w3.org/2000/svg" data-name="@item.name"><path d="m40 12h-18l-4-4h-10c-2.2 0-4 1.8-4 4v8h40v-4c0-2.2-1.8-4-4-4z" fill="#ffa000" /><path d="m40 12h-32c-2.2 0-4 1.8-4 4v20c0 2.2 1.8 4 4 4h32c2.2 0 4-1.8 4-4v-20c0-2.2-1.8-4-4-4z" fill="#ffca28" /></svg>

                         }
                         <figcaption>
                              <a asp-action="Index" asp-controller="Photos" asp-area="pCloud" asp-route-id="@item.folderid" asp-route-name="@item.name">@item.name</a>
                         </figcaption>
                    </figure>
               }
          </section>
     }
</div>

@functions {
     string GetFileId(string name)
     {
          var album = _db.Albums.Where(a => a.Name == name).FirstOrDefault();
          return album!.CoverPhoto!;
     }




     string GetThumbs(string path, string size)
     {
          try
          {
               var client = new RestClient("https://eapi.pcloud.com/");
               var request = new RestRequest("getthumblink");
               request.AddParameter("access_token", Context.Session.GetString("PCloudToken"));
               request.AddParameter("path", path);
               request.AddParameter("size", size);
               var response = client.Execute(request);
               var result = JsonConvert.DeserializeObject(response.Content!);
               StringBuilder sb = new StringBuilder();
               JToken json = JToken.Parse(result!.ToString()!);
               var url = "https://" + json["hosts"]![0] + json["path"];
               return url;
          }
          catch (NullReferenceException)
          {
               return string.Empty;
          }
     }
}


