@{
}
@model List<Posts>
@inject ApplicationDbContext _db
@inject IHttpContextAccessor _http
@using Microsoft.Extensions.Hosting
<!-- IWebHostEnvironment has been replaced with IHostEnvironment in .NET 5.0 and later. -->
@inject IHostEnvironment _env



<div id="Blog">
	<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="#9ff739" fill-opacity="1" d="M0,128L48,149.3C96,171,192,213,288,240C384,267,480,277,576,240C672,203,768,117,864,90.7C960,64,1056,96,1152,144C1248,192,1344,256,1392,288L1440,320L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>



	@if (_db.Posts.Count() == 0)
	{
		<p>No posts have been found just now.  Please check back later.</p>
	}
	else
	{
		<section>
			<h1>Blog</h1>

			@foreach (Posts post in _db.Posts)
			{
				var result = Truncate(post.PostContent!, 200);

				<div class="card">
					<img src="/Uploads/@post.FeaturedImage">
					<div class="card-body">
						<h2>@post.PostTitle</h2>
						@RemoveHTMLTags(result)
					</div>
					<div class="card-footer">
						<a asp-action="SinglePost" asp-area="Blog" asp-route-id="@post.PostID" class="btn btn-primary">Read More</a>
					</div>
				</div>
			}
			<div>
			<button type="button" class="loadMorePosts btn btn-info">See More</button>
			<button type="button" class="loadLessPosts btn btn-info">See Less</button>
			</div>
		</section>
	}
	<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="#9ff739" fill-opacity="1" d="M0,96L48,128C96,160,192,224,288,213.3C384,203,480,117,576,90.7C672,64,768,96,864,138.7C960,181,1056,235,1152,234.7C1248,235,1344,181,1392,154.7L1440,128L1440,0L1392,0C1344,0,1248,0,1152,0C1056,0,960,0,864,0C768,0,672,0,576,0C480,0,384,0,288,0C192,0,96,0,48,0L0,0Z"></path></svg>
</div>


@functions {


	public static string Truncate(string value, int maxChars)
	{
		return value.Length <= maxChars ? value : value.Substring(0, maxChars) + ".....";
	}

	public static string RemoveHTMLTags(string html)
	{
		return System.Text.RegularExpressions.Regex.Replace(html, "<.*?>", string.Empty);
	}
}