@{
}
@model BlogCommentViewModel
@using X.PagedList
@using X.PagedList.Extensions
@using X.Web.PagedList


<div id="Comments">
   
    <hr>
    <form method="post" asp-action="AddComment" asp-area="Blog" asp-controller="Comments" asp-route-id="@ViewData["id"]">
        <div asp-validation-summary="All" class="text-danger"></div>
        <div>
            <label asp-for="Comment.CommentAuthor">Name:</label>
            <input asp-for="Comment.CommentAuthor" placeholder="John Smith">
        </div>
        <div>
            <label asp-for="Comment!.CommentAuthorEmail">Email:</label>
            <input type="email" asp-for="Comment!.CommentAuthorEmail" placeholder="john@johnsmith.com">
        </div>
        <div>
            <label asp-for="Comment!.CommentAuthorUrl">Url:</label>
            <input asp-for="Comment!.CommentAuthorUrl" placeholder="https://www.johnsmith.com">
        </div>
        <div>
            <label asp-for="Comment.CommentContent">Comment:</label>
            <textarea id="ckeditor1" asp-for="Comment.CommentContent"></textarea>
        </div>
        <input type="hidden" asp-for="Comment.PostID" value="@ViewData["id"]">
        <div class="g-recaptcha" data-sitekey="6Lcu4zIqAAAAAGwRGrbhwIT_VWW4NVA5tbnSKgDB"></div>
        <button type="submit" class="btn btn-primary">Submit</button>
    </form>
</div>

