@{
    ViewData["id"] = Context.Request.Query["id"];
}
@model PersonalWebsiteMVC.Areas.Blog.Models.BlogCommentViewModel

<div id="Post">
    <section>
        <article>
            @try
            {
                <h1>@Model.Post!.PostTitle</h1>

                @Html.Raw(Model.Post!.PostContent)
            }
            catch (NullReferenceException ex)
            {
                @ex.Message
            }


            <partial name="~/Areas/Blog/Views/Shared/Comments.cshtml" model="@Model" view-data="ViewData" />
        </article>
        <article>
        </article>
    </section>
</div>